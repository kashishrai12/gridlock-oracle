# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.ipynb_checkpoints/

# ── Virtual environments ───────────────────────────────
venv/
.venv/
env/
ENV/
gridlock/            # local conda/venv folder name

# ── OS / IDE ───────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
